<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Transfer Proxy</title>
<style>
/* ===== 深色主题（默认） ===== */
:root {
    --bg: #1a1a2e;
    --bg-header: #16213e;
    --bg-card: #1e293b;
    --bg-row-hover: #1f2b47;
    --bg-detail: #12122a;
    --bg-pre: #0a0a1a;
    --bg-input: #0f172a;
    --border: #0f3460;
    --border-light: #334155;
    --border-row: #2a2a4a;
    --text: #e0e0e0;
    --text-secondary: #aaa;
    --text-muted: #888;
    --text-dim: #555;
    --text-dim-sub: #444;
    --accent: #e94560;
    --accent-hover: #c73a52;
    --green: #4ade80;
    --green-hover: #3cb868;
    --green-bg: rgba(16, 185, 129, 0.08);
    --red: #f87171;
    --red-hover: #dc2626;
    --blue: #3b82f6;
    --blue-hover: #2563eb;
    --purple: #7c3aed;
    --emerald: #10b981;
    --orange: #d97706;
    --teal: #10a37f;
    --modal-overlay: rgba(0,0,0,0.6);
    --modal-shadow: rgba(0,0,0,0.5);
    --cancel-bg: #374151;
    --cancel-bg-hover: #4b5563;
    --cancel-text: #ccc;
}

/* ===== 浅色主题 ===== */
[data-theme="light"] {
    --bg: #f1f5f9;
    --bg-header: #ffffff;
    --bg-card: #ffffff;
    --bg-row-hover: #eef2ff;
    --bg-detail: #f8fafc;
    --bg-pre: #e2e8f0;
    --bg-input: #ffffff;
    --border: #e2e8f0;
    --border-light: #cbd5e1;
    --border-row: #e2e8f0;
    --text: #1e293b;
    --text-secondary: #64748b;
    --text-muted: #94a3b8;
    --text-dim: #94a3b8;
    --text-dim-sub: #c0c8d4;
    --accent: #e94560;
    --accent-hover: #c73a52;
    --green: #16a34a;
    --green-hover: #15803d;
    --green-bg: rgba(16, 185, 129, 0.06);
    --red: #dc2626;
    --red-hover: #b91c1c;
    --blue: #2563eb;
    --blue-hover: #1d4ed8;
    --purple: #7c3aed;
    --emerald: #059669;
    --orange: #d97706;
    --teal: #0d9488;
    --modal-overlay: rgba(0,0,0,0.4);
    --modal-shadow: rgba(0,0,0,0.15);
    --cancel-bg: #e2e8f0;
    --cancel-bg-hover: #cbd5e1;
    --cancel-text: #475569;
}

* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; }
.header { background: var(--bg-header); padding: 16px 24px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border); }
.header h1 { font-size: 18px; color: var(--accent); }
.header-right { display: flex; align-items: center; gap: 16px; }

/* 主题切换按钮 */
.theme-btn { background: none; border: 1px solid var(--border-light); color: var(--text-secondary); padding: 6px 12px; border-radius: 6px; cursor: pointer; font-size: 13px; transition: all 0.2s; }
.theme-btn:hover { border-color: var(--accent); color: var(--accent); }

/* Tab */
.tab-nav { display: flex; gap: 0; background: var(--bg-header); padding: 0 24px; border-bottom: 1px solid var(--border); }
.tab-btn { padding: 12px 24px; border: none; background: none; color: var(--text-muted); cursor: pointer; font-size: 14px; border-bottom: 2px solid transparent; margin-bottom: -1px; transition: all 0.2s; }
.tab-btn:hover { color: var(--text-secondary); }
.tab-btn.active { color: var(--accent); border-bottom-color: var(--accent); }
.tab-panel { display: none; }
.tab-panel.active { display: block; }

.container { max-width: 1400px; margin: 0 auto; padding: 20px; }

/* 按钮 */
.btn { padding: 8px 20px; border: none; border-radius: 6px; cursor: pointer; font-size: 14px; transition: all 0.2s; }
.btn-add { background: var(--green); color: #fff; }
.btn-add:hover { background: var(--green-hover); }
.btn-clear { background: var(--accent); color: #fff; }
.btn-clear:hover { background: var(--accent-hover); }
.btn-edit { background: var(--blue); color: #fff; padding: 6px 14px; font-size: 12px; margin-right: 6px; }
.btn-edit:hover { background: var(--blue-hover); }
.btn-del { background: var(--red); color: #fff; padding: 6px 14px; font-size: 12px; }
.btn-del:hover { background: var(--red-hover); }
.btn-cancel { background: var(--cancel-bg); color: var(--cancel-text); }
.btn-cancel:hover { background: var(--cancel-bg-hover); }
.btn-save { background: var(--green); color: #fff; }
.btn-save:hover { background: var(--green-hover); }
.top-actions { display: flex; gap: 12px; align-items: center; margin-bottom: 16px; }
.record-count { font-size: 13px; color: var(--text-muted); margin-left: auto; }

/* 连接状态指示 */
.conn-dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; margin-right: 6px; }
.conn-dot.on { background: var(--green); }
.conn-dot.off { background: var(--red); }
.conn-status { font-size: 12px; color: var(--text-muted); }

/* 表格 */
table { width: 100%; border-collapse: collapse; font-size: 13px; }
thead th { background: var(--bg-header); padding: 12px 10px; text-align: left; font-weight: 500; color: var(--text-secondary); border-bottom: 2px solid var(--border); }
tbody td { padding: 10px; border-bottom: 1px solid var(--border-row); }
tbody tr { cursor: pointer; transition: background 0.15s; }
tbody tr:hover { background: var(--bg-row-hover); }
.status-ok { color: var(--green); }
.status-err { color: var(--red); }
.token-cell { font-family: 'SF Mono', 'Consolas', monospace; }
.detail-row { display: none; }
.detail-row.show { display: table-row; }
.detail-row td { background: var(--bg-detail); padding: 0; }
.detail-content { padding: 16px 20px; max-height: 400px; overflow: auto; }
.detail-section { margin-bottom: 12px; }
.detail-section h4 { font-size: 12px; color: var(--accent); margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.5px; }
.detail-section pre { font-size: 12px; color: var(--text-secondary); white-space: pre-wrap; word-break: break-all; background: var(--bg-pre); padding: 10px; border-radius: 4px; max-height: 200px; overflow: auto; }
.stream-badge { display: inline-block; background: var(--purple); color: #fff; font-size: 10px; padding: 2px 6px; border-radius: 3px; margin-left: 4px; }
.streaming-badge { display: inline-block; background: var(--emerald); color: #fff; font-size: 10px; padding: 2px 6px; border-radius: 3px; margin-left: 4px; animation: pulse 1.5s ease-in-out infinite; }
@keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
.recording-streaming { background: var(--green-bg); }
.dur-live { color: var(--emerald); }
.empty-state { text-align: center; padding: 80px 20px; color: var(--text-dim); }
.empty-state p { font-size: 16px; margin-bottom: 8px; }
.empty-state .sub { font-size: 13px; color: var(--text-dim-sub); }

/* 规则管理 */
.format-badge { display: inline-block; padding: 2px 10px; border-radius: 3px; font-size: 11px; font-weight: 500; }
.format-openai { background: var(--teal); color: #fff; }
.format-anthropic { background: var(--orange); color: #fff; }
.rule-name { color: var(--text); }
.rule-table tbody tr { cursor: default; }

/* 弹窗 */
.modal-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: var(--modal-overlay); z-index: 100; justify-content: center; align-items: center; }
.modal-overlay.show { display: flex; }
.modal { background: var(--bg-card); border-radius: 12px; padding: 24px; width: 480px; max-width: 90vw; box-shadow: 0 20px 60px var(--modal-shadow); }
.modal h3 { font-size: 16px; color: var(--text); margin-bottom: 20px; }
.form-group { margin-bottom: 14px; }
.form-group label { display: block; font-size: 13px; color: var(--text-secondary); margin-bottom: 4px; }
.form-group input, .form-group select { width: 100%; padding: 10px 12px; background: var(--bg-input); border: 1px solid var(--border-light); border-radius: 6px; color: var(--text); font-size: 14px; outline: none; transition: border-color 0.2s; }
.form-group input:focus, .form-group select:focus { border-color: var(--green); }
.modal-actions { display: flex; gap: 10px; justify-content: flex-end; margin-top: 20px; }
</style>
</head>
<body>
<div class="header">
    <h1>Transfer Proxy</h1>
    <div class="header-right">
        <button class="theme-btn" onclick="toggleTheme()" id="themeBtn">浅色</button>
        <div class="conn-status"><span class="conn-dot on" id="connDot"></span><span id="connLabel">SSE 已连接</span></div>
    </div>
</div>

<!-- Tab 导航 -->
<div class="tab-nav">
    <button class="tab-btn active" onclick="switchTab('records')">请求记录</button>
    <button class="tab-btn" onclick="switchTab('rules')">代理规则</button>
</div>

<!-- 请求记录 Tab -->
<div class="tab-panel active" id="panel-records">
    <div class="container">
        <div class="top-actions">
            <button class="btn btn-clear" onclick="clearRecords()">清除全部记录</button>
            <span class="record-count" id="recordCount">0 条记录</span>
        </div>
        <div class="empty-state" id="emptyState">
            <p>暂无请求记录</p>
            <p class="sub">发送请求到代理端口后将在此实时显示</p>
        </div>
        <table id="recordTable" style="display:none;">
            <thead>
                <tr>
                    <th style="width:160px;">完成时间</th>
                    <th style="width:70px;">方法</th>
                    <th style="width:180px;">路径</th>
                    <th style="width:70px;">状态码</th>
                    <th style="width:100px;">模型</th>
                    <th style="width:80px;">输入Token</th>
                    <th style="width:80px;">输出Token</th>
                    <th style="width:80px;">耗时</th>
                </tr>
            </thead>
            <tbody id="tableBody"></tbody>
        </table>
    </div>
</div>

<!-- 代理规则 Tab -->
<div class="tab-panel" id="panel-rules">
    <div class="container">
        <div class="top-actions">
            <button class="btn btn-add" onclick="showRuleModal()">+ 新建规则</button>
            <span class="record-count" id="ruleCount">0 条规则</span>
        </div>
        <div class="empty-state" id="rulesEmpty">
            <p>暂无代理规则</p>
            <p class="sub">点击"新建规则"创建第一条转发规则</p>
        </div>
        <table class="rule-table" id="ruleTable" style="display:none;">
            <thead>
                <tr>
                    <th style="width:140px;">名称</th>
                    <th style="width:100px;">端口</th>
                    <th>目标地址</th>
                    <th style="width:90px;">格式</th>
                    <th style="width:140px;">操作</th>
                </tr>
            </thead>
            <tbody id="ruleTableBody"></tbody>
        </table>
    </div>
</div>

<!-- 规则编辑弹窗 -->
<div class="modal-overlay" id="ruleModal">
    <div class="modal">
        <h3 id="modalTitle">新建代理规则</h3>
        <input type="hidden" id="ruleId">
        <div class="form-group"><label>规则名称</label><input type="text" id="ruleName" placeholder="例如：OpenAI代理"></div>
        <div class="form-group"><label>监听端口</label><input type="number" id="rulePort" placeholder="例如：8080"></div>
        <div class="form-group"><label>目标地址</label><input type="text" id="ruleTarget" placeholder="例如：https://api.openai.com"></div>
        <div class="form-group"><label>API 格式</label><select id="ruleFormat"><option value="openai">OpenAI</option><option value="anthropic">Anthropic</option></select></div>
        <div class="modal-actions">
            <button class="btn btn-cancel" onclick="hideRuleModal()">取消</button>
            <button class="btn btn-save" onclick="saveRule()">保存</button>
        </div>
    </div>
</div>

<script>
// ========== 主题切换 ==========
function getTheme() { return localStorage.getItem('transfer-theme') || 'dark'; }
function setTheme(t) {
    document.documentElement.setAttribute('data-theme', t);
    localStorage.setItem('transfer-theme', t);
    document.getElementById('themeBtn').textContent = t === 'dark' ? '浅色' : '深色';
}
function toggleTheme() { setTheme(getTheme() === 'dark' ? 'light' : 'dark'); }
setTheme(getTheme());

// ========== Tab 切换 ==========
let currentTab = 'records';
function switchTab(tab) {
    currentTab = tab;
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    document.querySelector(`.tab-btn[onclick="switchTab('${tab}')"]`).classList.add('active');
    document.getElementById('panel-' + tab).classList.add('active');
    if (tab === 'records') renderRecords();
    if (tab === 'rules') fetchRules();
}

// ========== SSE 实时连接 ==========
let records = [];
let recordMap = new Map();
let expandedId = null;
let es = null;

function connectSSE() {
    es = new EventSource('/api/events');
    es.onopen = function() {
        document.getElementById('connDot').className = 'conn-dot on';
        document.getElementById('connLabel').textContent = 'SSE 已连接';
    };
    es.onmessage = function(e) {
        try {
            const evt = JSON.parse(e.data);
            if (evt.type === 'init') {
                records = evt.all || [];
                rebuildMap();
            } else if (evt.type === 'update' && evt.record) {
                const idx = records.findIndex(r => r.id === evt.record.id);
                if (idx >= 0) {
                    records[idx] = evt.record;
                } else {
                    records.unshift(evt.record);
                }
                recordMap.set(evt.record.id, evt.record);
            }
            if (currentTab === 'records') renderRecords();
        } catch (_) {}
    };
    es.onerror = function() {
        document.getElementById('connDot').className = 'conn-dot off';
        document.getElementById('connLabel').textContent = 'SSE 断开，重连中...';
        es.close();
        setTimeout(connectSSE, 3000);
    };
}

function rebuildMap() {
    recordMap.clear();
    for (const r of records) recordMap.set(r.id, r);
}

function renderRecords() {
    const count = records.length;
    document.getElementById('recordCount').textContent = count + ' 条记录';
    document.getElementById('emptyState').style.display = count === 0 ? 'block' : 'none';
    document.getElementById('recordTable').style.display = count === 0 ? 'none' : 'table';

    let html = '';
    for (const r of records) {
        const completed = r.completed !== false;
        const time = completed ? new Date(r.complete_time).toLocaleString('zh-CN') : '--';
        const sc = r.status_code >= 200 && r.status_code < 300 ? 'status-ok' : 'status-err';
        const dur = completed ? (r.duration_ms >= 1000 ? (r.duration_ms / 1000).toFixed(1) + 's' : r.duration_ms + 'ms') : '<span class="dur-live">进行中</span>';
        let badge = '';
        if (!completed) {
            badge = '<span class="streaming-badge">进行中</span>';
        } else if (r.is_stream) {
            badge = '<span class="stream-badge">流式</span>';
        }
        const rowClass = !completed ? ' recording-streaming' : '';
        html += '<tr class="' + rowClass + '" onclick="toggleDetail(\'' + r.id + '\')">' +
            '<td>' + time + '</td>' +
            '<td>' + r.method + '</td>' +
            '<td>' + escHtml(truncate(r.path, 40)) + badge + '</td>' +
            '<td class="' + sc + '">' + r.status_code + '</td>' +
            '<td>' + escHtml(truncate(r.model, 15)) + '</td>' +
            '<td class="token-cell">' + (r.input_tokens || '-') + '</td>' +
            '<td class="token-cell">' + (r.output_tokens || '-') + '</td>' +
            '<td>' + dur + '</td></tr>';
        const show = expandedId === r.id ? ' show' : '';
        html += '<tr class="detail-row' + show + '" id="detail-' + r.id + '"><td colspan="8"><div class="detail-content">' + buildDetail(r) + '</div></td></tr>';
    }
    document.getElementById('tableBody').innerHTML = html;
}

function buildDetail(r) {
    let h = '';
    if (r.rule_id) h += '<div class="detail-section"><h4>规则 ID</h4><pre>' + escHtml(r.rule_id) + '</pre></div>';
    h += '<div class="detail-section"><h4>请求 Headers</h4><pre>' + escHtml(JSON.stringify(r.headers, null, 2)) + '</pre></div>';
    h += '<div class="detail-section"><h4>Query 参数</h4><pre>' + escHtml(JSON.stringify(r.query_params, null, 2)) + '</pre></div>';
    h += '<div class="detail-section"><h4>请求 Body</h4><pre>' + escHtml(truncate(r.body, 5000)) + '</pre></div>';
    if (r.is_stream && r.stream_chunks) {
        h += '<div class="detail-section"><h4>流式响应 (' + r.stream_chunks.length + ' 条)</h4><pre>' + escHtml(r.response_body || '') + '</pre></div>';
    } else {
        h += '<div class="detail-section"><h4>响应 Body</h4><pre>' + escHtml(truncate(r.response_body, 5000)) + '</pre></div>';
    }
    return h;
}

function toggleDetail(id) {
    expandedId = expandedId === id ? null : id;
    renderRecords();
}

async function clearRecords() {
    if (!confirm('确定清除所有记录？此操作不可恢复。')) return;
    await fetch('/api/records/clear', { method: 'POST' });
    records = [];
    recordMap.clear();
    expandedId = null;
    renderRecords();
}

// ========== 代理规则管理 ==========
let rules = [];

async function fetchRules() {
    try { const r = await fetch('/api/rules'); rules = await r.json(); renderRules(); }
    catch (e) { console.error(e); }
}

function renderRules() {
    document.getElementById('ruleCount').textContent = rules.length + ' 条规则';
    document.getElementById('rulesEmpty').style.display = rules.length === 0 ? 'block' : 'none';
    document.getElementById('ruleTable').style.display = rules.length === 0 ? 'none' : 'table';
    let h = '';
    for (const r of rules) {
        const fc = r.format === 'openai' ? 'format-openai' : 'format-anthropic';
        const fl = r.format === 'openai' ? 'OpenAI' : 'Anthropic';
        h += '<tr><td class="rule-name">' + escHtml(r.name || '未命名') + '</td><td>' + r.port + '</td><td>' + escHtml(truncate(r.target_url, 50)) +
            '</td><td><span class="format-badge ' + fc + '">' + fl + '</span></td>' +
            '<td><button class="btn btn-edit" onclick="editRule(\'' + r.id + '\')">编辑</button>' +
            '<button class="btn btn-del" onclick="deleteRule(\'' + r.id + '\')">删除</button></td></tr>';
    }
    document.getElementById('ruleTableBody').innerHTML = h;
}

function showRuleModal() {
    document.getElementById('modalTitle').textContent = '新建代理规则';
    document.getElementById('ruleId').value = '';
    document.getElementById('ruleName').value = '';
    document.getElementById('rulePort').value = '';
    document.getElementById('ruleTarget').value = '';
    document.getElementById('ruleFormat').value = 'openai';
    document.getElementById('ruleModal').classList.add('show');
}

function editRule(id) {
    const r = rules.find(r => r.id === id); if (!r) return;
    document.getElementById('modalTitle').textContent = '编辑代理规则';
    document.getElementById('ruleId').value = r.id;
    document.getElementById('ruleName').value = r.name || '';
    document.getElementById('rulePort').value = r.port;
    document.getElementById('ruleTarget').value = r.target_url;
    document.getElementById('ruleFormat').value = r.format;
    document.getElementById('ruleModal').classList.add('show');
}

function hideRuleModal() { document.getElementById('ruleModal').classList.remove('show'); }

async function saveRule() {
    const id = document.getElementById('ruleId').value;
    const name = document.getElementById('ruleName').value.trim();
    const port = parseInt(document.getElementById('rulePort').value);
    const target = document.getElementById('ruleTarget').value.trim();
    const fmt = document.getElementById('ruleFormat').value;
    if (!port || !target) { alert('端口和目标地址为必填项'); return; }
    try {
        let resp;
        if (id) resp = await fetch('/api/rules?id=' + encodeURIComponent(id), { method: 'PUT', body: JSON.stringify({name, port, target_url: target, format: fmt}) });
        else resp = await fetch('/api/rules', { method: 'POST', body: JSON.stringify({name, port, target_url: target, format: fmt}) });
        const d = await resp.json();
        if (d.error) { alert('操作失败: ' + d.error); return; }
        hideRuleModal(); await fetchRules();
    } catch (e) { alert('操作失败: ' + e.message); }
}

async function deleteRule(id) {
    const r = rules.find(r => r.id === id);
    if (!confirm('确定删除规则 "' + (r ? r.name : id) + '"？')) return;
    try {
        const resp = await fetch('/api/rules?id=' + encodeURIComponent(id), { method: 'DELETE' });
        const d = await resp.json();
        if (d.error) { alert('删除失败: ' + d.error); return; }
        await fetchRules();
    } catch (e) { alert('删除失败: ' + e.message); }
}

// ========== 工具函数 ==========
function escHtml(s) { if (!s) return ''; return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;'); }
function truncate(s, n) { if (!s) return ''; if (s.length <= n) return s; return s.substring(0, n) + '... [截断]'; }

// ========== 初始化 ==========
connectSSE();
fetchRules();
</script>
</body>
</html>
